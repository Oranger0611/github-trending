# Copy to .env for local runs:  cp .env.example .env
# (.env is git-ignored. In GitHub Actions these become repository Secrets.)

# ── Behavior (configure how it runs, right here in .env) ──────────────
# Where the result goes:
#   html  -> save a local HTML file and open it (no email needed)
#   email -> send via Gmail (needs the Gmail settings below)
OUTPUT=html

# How the digest is written:
#   digest -> one LLM call for all repos (fast, cheap)
#   detail -> one LLM call per repo + README (deeper)
MODE=digest

# Model name. Leave UNSET to use your provider's default. Set it to pick a
# specific model for whichever provider you configured above, e.g.:
#   Claude  -> claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
#   OpenAI  -> gpt-4o-mini | gpt-4o
#   Gemini  -> gemini-2.0-flash | gemini-2.5-pro
# MODEL=claude-opus-4-8

# Optional, only used when OUTPUT=html:
# OUTPUT_PATH=/Users/you/Desktop/trending.html   # default: output/trending-<date>.html
# OPEN_BROWSER=true                               # set false to not auto-open


# ── LLM provider: set exactly ONE of these keys. It auto-detects. ──
# Pick based on cost/availability — the app works the same with any of them.
ANTHROPIC_API_KEY=sk-ant-...   # Claude  — https://console.anthropic.com/settings/keys
# OPENAI_API_KEY=sk-...        # OpenAI  — https://platform.openai.com/api-keys
# GEMINI_API_KEY=...           # Gemini  — https://aistudio.google.com/apikey
# QWEN_API_KEY=...             # Qwen    — https://dashscope.console.aliyun.com/ (free tokens)

# Only if you set MORE THAN ONE key above, pick which to use:
# LLM_PROVIDER=qwen            # anthropic | openai | gemini | qwen

# ── The Gmail settings below are only needed to EMAIL the digest. ──
# ── Skip them if you only use local HTML mode (--html). ──

# Gmail account that SENDS the email
GMAIL_USER=you@gmail.com

# Gmail APP PASSWORD (16 chars, NOT your login password)
# Create at: https://myaccount.google.com/apppasswords  (requires 2FA on)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Where to send the digest. Optional — defaults to GMAIL_USER (yourself).
# Comma-separate for multiple recipients.
MAIL_TO=you@gmail.com
